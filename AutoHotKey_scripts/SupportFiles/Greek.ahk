; Greek Alphabet
; Each letter is registered as a symbol button on the "Greek" tab.
; Layout: 4 rows, going down then across.

GREEK_TAB := 4
SetTabName( GREEK_TAB, "Greek" )


; Column 1: Α Β Γ Δ
RegisterSymbol( 1, 1, GREEK_TAB, "Α", "Alpha",   "Α" )
RegisterSymbol( 2, 1, GREEK_TAB, "Β", "Beta",    "Β" )
RegisterSymbol( 3, 1, GREEK_TAB, "Γ", "Gamma",   "Γ" )
RegisterSymbol( 4, 1, GREEK_TAB, "Δ", "Delta",   "Δ" )

; Column 2: Ε Ζ Η Θ
RegisterSymbol( 1, 2, GREEK_TAB, "Ε", "Epsilon",  "Ε" )
RegisterSymbol( 2, 2, GREEK_TAB, "Ζ", "Zeta",     "Ζ" )
RegisterSymbol( 3, 2, GREEK_TAB, "Η", "Eta",      "Η" )
RegisterSymbol( 4, 2, GREEK_TAB, "Θ", "Theta",    "Θ" )

; Column 3: Ι Κ Λ Μ
RegisterSymbol( 1, 3, GREEK_TAB, "Ι", "Iota",     "Ι" )
RegisterSymbol( 2, 3, GREEK_TAB, "Κ", "Kappa",    "Κ" )
RegisterSymbol( 3, 3, GREEK_TAB, "Λ", "Lambda",   "Λ" )
RegisterSymbol( 4, 3, GREEK_TAB, "Μ", "Mu",       "Μ" )

; Column 4: Ν Ξ Ο Π
RegisterSymbol( 1, 4, GREEK_TAB, "Ν", "Nu",       "Ν" )
RegisterSymbol( 2, 4, GREEK_TAB, "Ξ", "Xi",       "Ξ" )
RegisterSymbol( 3, 4, GREEK_TAB, "Ο", "Omicron",  "Ο" )
RegisterSymbol( 4, 4, GREEK_TAB, "Π", "Pi",       "Π" )

; Column 5: Ρ Σ Τ Υ
RegisterSymbol( 1, 5, GREEK_TAB, "Ρ", "Rho",      "Ρ" )
RegisterSymbol( 2, 5, GREEK_TAB, "Σ", "Sigma",    "Σ" )
RegisterSymbol( 3, 5, GREEK_TAB, "Τ", "Tau",      "Τ" )
RegisterSymbol( 4, 5, GREEK_TAB, "Υ", "Upsilon",  "Υ" )

; Column 6: Φ Χ Ψ Ω
RegisterSymbol( 1, 6, GREEK_TAB, "Φ", "Phi",      "Φ" )
RegisterSymbol( 2, 6, GREEK_TAB, "Χ", "Chi",      "Χ" )
RegisterSymbol( 3, 6, GREEK_TAB, "Ψ", "Psi",      "Ψ" )
RegisterSymbol( 4, 6, GREEK_TAB, "Ω", "Omega",    "Ω" )
